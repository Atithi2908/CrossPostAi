# Database Configuration (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@hostname:5432/dbname

# JWT & Security
JWT_SECRET_KEY=your_secure_random_string_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Frontend URL (For OAuth redirects and CORS)
FRONTEND_URL=https://your-frontend-domain.com

# AI API Keys
DEEPGRAM_API_KEY=your_deepgram_api_key
GROQ_API_KEY=your_groq_api_key
AUTOMATION_API_KEY=your_cron_secret_here

# Instagram OAuth
INSTAGRAM_CLIENT_ID=your_instagram_client_id
INSTAGRAM_CLIENT_SECRET=your_instagram_client_secret
INSTAGRAM_REDIRECT_URI=https://your-backend-domain.com/instagram/callback

# LinkedIn OAuth
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_REDIRECT_URI=https://your-backend-domain.com/linkedin/callback
